import java.util.Scanner;
// Constrained code ends here
// Create your class here with static methods inside
class MyMath {

    // Method 1: add two integers
    static void add(int a, int b) {
        System.out.println(a + b);
    }

    // Method 2: add three double values
    static void add(double a, double b, double c) {
        System.out.println(a + b + c);
    }

    // Method 3: add ASCII values of two characters
    static void add(char a, char b) {
        System.out.println((int) a + (int) b);
    }

    // Method 4: add all elements of int array
    static void add(int[] arr) {
        int sum = 0;
        for (int num : arr) {
            sum += num;
        }
        System.out.println(sum);
    }

    // Method 5: concatenate first letters of all strings
    static void add(String[] arr) {
        String result = "";
        for (String s : arr) {
            result += s.charAt(0);
        }
        System.out.println(result);
    }

    // Method 6: sum ASCII values of all characters in string
    static void add(String s) {
        int sum = 0;
        for (int i = 0; i < s.length(); i++) {
            sum += s.charAt(i);
        }
        System.out.println(sum);
    }
}

// Constrained code starts here
public class MethodOverloadDemo {
    public static void main(String[] args) {
        Scanner read = new Scanner(System.in);
        // reading 2 integers
        int a = read.nextInt();
        int b = read.nextInt();

        // reading 3 double values
        double x = read.nextDouble();
        double y = read.nextDouble();
        double z = read.nextDouble();

        // reading two characters
        char ch1 = read.next().charAt(0);
        char ch2 = read.next().charAt(0);

        // reading an integer array
        int n = read.nextInt();
        int[] A = new int[n];
        for (int i = 0; i < n; i++) A[i] = read.nextInt();

        // reading an array of strings
        int m = read.nextInt();
        String names[] = new String[m];
        for (int i = 0; i < m; i++) names[i] = read.next();

        // reading a single string
        read.nextLine(); // to consume extra enter
        String s = read.nextLine();

        // Methods calls
        // Calling method 1
        MyMath.add(a, b);
        // Calling method 2
        MyMath.add(x, y, z);
        // Calling method 3
        MyMath.add(ch1, ch2);
         // Calling method 4
        MyMath.add(A);
        // Calling method 5
        MyMath.add(names);
        // Calling method 6
        MyMath.add(s);
    }
}
// Constrained code ends here
